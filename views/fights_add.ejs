<!DOCTYPE html>
<html lang="en">

<head>
    <link rel="stylesheet" href="/css/Navbar.css" />
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>
        <%= title %> - Thêm chuyến bay
    </title>
</head>
<body>
    <div class="container-fluid min-vh-100 px-1 d-flex flex-column">
        <%- include('Navbar') %>
            <div class="container my-5 flex-grow-1">
                <div class="row justify-content-center">
                    <div class="col-md-6">
                        <h2 class="mb-4">Thêm Chuyến Bay Mới</h2>
                        <form method="POST" action="/flight/Them">
                            <div class="mb-3" style="position:relative;">
                                <label for="name" class="form-label">Tên Gọi Chuyến Bay</label>
                                <input type="text" class="form-control" id="name" name="name" placeholder="VD: Hà Nội - TP.HCM" autocomplete="on" required>
                            </div>
                            <div class="mb-3">
                                <label for="numberseats" class="form-label">Số Ghế Tổng Thể</label>
                                <input type="number" class="form-control" id="numberseats" name="numberseats" placeholder="VD: 180" required>
                            </div>
                            <div class="mb-3">
                                <label for="airline" class="form-label">Hãng Máy Bay</label>
                                <input type="text" class="form-control" id="airline" name="airline" placeholder="VD: Vietnam Airlines" required>
                            </div>
                            <div class="mb-3">
                                <label for="airplane" class="form-label">Mẫu Máy Bay</label>
                                <input type="text" class="form-control" id="airplane" name="airplane" placeholder="VD: Boeing 787 Dreamliner" required>
                            </div>
                            <div class="mb-3">
                                <label for="from_airport" class="form-label">Sân Bay Khởi Hành</label>
                                <input type="text" class="form-control" id="from_airport" name="from_airport" placeholder="VD: Nội Bài (HAN), Hà Nội" required>
                            </div>
                            <div class="mb-3">
                                <label for="to_airport" class="form-label">Sân Bay Đến</label>
                                <input type="text" class="form-control" id="to_airport" name="to_airport" placeholder="VD: Tân Sơn Nhất (SGN), TP.HCM" required>
                            </div>
                            <div class="mb-3">
                                <label for="flydate" class="form-label">Ngày Khởi Hành</label>
                                <input type="datetime-local" class="form-control" id="flydate" name="flydate" required>
                            </div>
                            <div class="mb-3">
                                <label for="price" class="form-label">Giá Vé (VNĐ)</label>
                                <input type="number" class="form-control" id="price" name="price" placeholder="VD: 1250000" required>
                            </div>
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Thêm Chuyến Bay</button>
                                <a href="/flight/danhsach" class="btn btn-secondary">Hủy</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <%- include('Footer') %>
                <%- include('Javascript') %>
    </div>
</body>

</html>