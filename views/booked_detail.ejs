<!DOCTYPE html>
<html lang="en">

<head>
    <link rel="stylesheet" href="/css/Navbar.css" />
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>
        <%= title %> - Chi Tiết Vé
    </title>
</head>

<body>

    <div class="container-fluid min-vh-100 px-1 d-flex flex-column">
        <%- include('Navbar') %>
        
        <div class="flex-grow-1 py-5">
            <div class="container">
                <!-- Breadcrumb -->
                <nav aria-label="breadcrumb" class="mb-4">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                        <li class="breadcrumb-item"><a href="/booking/DanhSachDatVe">Danh sách vé</a></li>
                        <li class="breadcrumb-item active">Chi tiết vé</li>
                    </ol>
                </nav>

                <% if (ticket && ticket.chuyenbay) { %>
                    <div class="row">
                        <!-- Vé Chi Tiết -->
                        <div class="col-lg-8 mb-4">
                            <!-- Thẻ vé chính -->
                            <div class="card border-0 shadow-lg mb-4">
                                <!-- Header của vé -->
                                <div class="card-header bg-primary text-white">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h4 class="mb-0">
                                                <i class="bi bi-ticket-perforated me-2"></i>VÉ MÁY BAY
                                            </h4>
                                        </div>
                                        <div class="text-end">
                                            <p class="mb-0 small">Mã Vé</p>
                                            <p class="mb-0 fw-bold"><%= ticket._id %></p>
                                        </div>
                                    </div>
                                </div>

                                <div class="card-body">
                                    <!-- Thông tin chuyến bay chính -->
                                    <div class="mb-4">
                                        <h5 class="mb-3">
                                            <i class="bi bi-airplane"></i> Thông Tin Chuyến Bay
                                        </h5>
                                        <div class="row">
                                            <div class="col-md-6">
                                                <p class="text-muted small mb-1">Mã Chuyến Bay</p>
                                                <p class="fw-bold fs-5"><%= ticket.chuyenbay.name %></p>
                                            </div>
                                            <div class="col-md-6">
                                                <p class="text-muted small mb-1">Hãng Hàng Không</p>
                                                <p class="fw-bold"><%= ticket.chuyenbay.airline %></p>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-6">
                                                <p class="text-muted small mb-1">Loại Máy Bay</p>
                                                <p class="fw-bold"><%= ticket.chuyenbay.airplane %></p>
                                            </div>
                                            <div class="col-md-6">
                                                <p class="text-muted small mb-1">Trạng Thái</p>
                                                <p class="fw-bold">
                                                    <% if (ticket.chuyenbay.status === 'active') { %>
                                                        <span class="badge bg-success">Có sẵn</span>
                                                    <% } else { %>
                                                        <span class="badge bg-warning"><%= ticket.chuyenbay.status %></span>
                                                    <% } %>
                                                </p>
                                            </div>
                                        </div>
                                    </div>

                                    <hr>

                                    <!-- Lộ trình chuyến bay -->
                                    <div class="mb-4">
                                        <h5 class="mb-3">
                                            <i class="bi bi-geo-alt-fill"></i> Lộ Trình
                                        </h5>
                                        <div class="row align-items-center">
                                            <div class="col-md-5">
                                                <div class="card bg-light border-0">
                                                    <div class="card-body text-center">
                                                        <p class="text-muted small mb-2">Điểm Xuất Phát</p>
                                                        <h4 class="mb-2"><%= ticket.chuyenbay.from_airport %></h4>
                                                        <p class="text-muted small">
                                                            <% 
                                                                const flyDate = new Date(ticket.chuyenbay.flydate);
                                                                const dateStr = flyDate.toLocaleDateString('vi-VN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
                                                                const timeStr = flyDate.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
                                                            %>
                                                            <%= dateStr %><br>
                                                            <%= timeStr %>
                                                        </p>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-2 text-center">
                                                <i class="bi bi-arrow-right fs-4 text-primary"></i>
                                            </div>
                                            <div class="col-md-5">
                                                <div class="card bg-light border-0">
                                                    <div class="card-body text-center">
                                                        <p class="text-muted small mb-2">Điểm Đến</p>
                                                        <h4 class="mb-2"><%= ticket.chuyenbay.to_airport %></h4>
                                                        <p class="text-muted small">Sân bay đích</p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <hr>

                                    <!-- Thông tin hành khách -->
                                    <div class="mb-4">
                                        <h5 class="mb-3">
                                            <i class="bi bi-person"></i> Thông Tin Hành Khách
                                        </h5>
                                        <div class="row">
                                            <div class="col-md-6">
                                                <p class="text-muted small mb-1">Họ và Tên</p>
                                                <p class="fw-bold"><%= ticket.Hoten %></p>
                                            </div>
                                            <div class="col-md-6">
                                                <p class="text-muted small mb-1">Ghế Đã Đặt</p>
                                                <p class="fw-bold"><span class="badge bg-info"><%= ticket.seatsplaced %></span></p>
                                            </div>
                                        </div>
                                    </div>

                                    <hr>

                                    <!-- Thông tin giá vé -->
                                    <div class="mb-4">
                                        <h5 class="mb-3">
                                            <i class="bi bi-cash-coin"></i> Thông Tin Giá Vé
                                        </h5>
                                        <div class="row">
                                            <div class="col-md-6">
                                                <p class="text-muted small mb-1">Giá Vé</p>
                                                <p class="fw-bold fs-5 text-success"><%= ticket.price.toLocaleString('vi-VN') %> ₫</p>
                                            </div>
                                            <div class="col-md-6">
                                                <p class="text-muted small mb-1">Ngày Đặt Vé</p>
                                                <p class="fw-bold">
                                                    <% 
                                                        const bookDate = new Date(ticket.datebooking);
                                                        const bookDateStr = bookDate.toLocaleDateString('vi-VN', { year: 'numeric', month: '2-digit', day: '2-digit' });
                                                        const bookTimeStr = bookDate.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
                                                    %>
                                                    <%= bookDateStr %> <%= bookTimeStr %>
                                                </p>
                                            </div>
                                        </div>
                                    </div>

                                    <% if (ticket.description) { %>
                                        <hr>
                                        <div class="mb-4">
                                            <h5 class="mb-3">
                                                <i class="bi bi-info-circle"></i> Ghi Chú
                                            </h5>
                                            <div class="alert alert-info" role="alert">
                                                <%= ticket.description %>
                                            </div>
                                        </div>
                                    <% } %>
                                </div>
                            </div>

                            <!-- Thông tin bổ sung -->
                            <div class="card border-0 shadow-sm">
                                <div class="card-body">
                                    <h5 class="mb-3">
                                        <i class="bi bi-check-circle"></i> Dịch Vụ Bao Gồm
                                    </h5>
                                    <ul class="list-unstyled">
                                        <li class="mb-2">
                                            <i class="bi bi-check text-success me-2"></i>
                                            Hành lý ký gửi: 20kg / hành khách
                                        </li>
                                        <li class="mb-2">
                                            <i class="bi bi-check text-success me-2"></i>
                                            Đồ ăn và thức uống miễn phí
                                        </li>
                                        <li class="mb-2">
                                            <i class="bi bi-check text-success me-2"></i>
                                            Có thể thay đổi lịch bay (phí từ 500,000 ₫)
                                        </li>
                                        <li class="mb-2">
                                            <i class="bi bi-check text-success me-2"></i>
                                            Bảo hiểm hành khách toàn diện
                                        </li>
                                        <li class="mb-2">
                                            <i class="bi bi-check text-success me-2"></i>
                                            Chọn ghế ưu tiên (miễn phí)
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <!-- Sidebar Hành Động -->
                        <div class="col-lg-4">
                            <!-- Card Thông Tin Nhanh -->
                            <div class="card border-0 shadow-lg mb-4 sticky-lg-top" style="top: 20px;">
                                <div class="card-header bg-success text-white">
                                    <h5 class="mb-0">
                                        <i class="bi bi-ticket-perforated me-2"></i>Tóm Tắt Vé
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <p class="text-muted small mb-1">Chuyến Bay</p>
                                        <p class="fw-bold mb-0"><%= ticket.chuyenbay.name %></p>
                                        <small class="text-muted"><%= ticket.chuyenbay.airline %></small>
                                    </div>

                                    <hr>

                                    <div class="mb-3">
                                        <p class="text-muted small mb-1">Lộ Trình</p>
                                        <p class="fw-bold mb-0">
                                            <%= ticket.chuyenbay.from_airport %> <i class="bi bi-arrow-right"></i> <%= ticket.chuyenbay.to_airport %>
                                        </p>
                                    </div>

                                    <hr>

                                    <div class="mb-3">
                                        <p class="text-muted small mb-1">Ghế Của Bạn</p>
                                        <p class="fw-bold mb-0">
                                            <span class="badge bg-info"><%= ticket.seatsplaced %></span>
                                        </p>
                                    </div>

                                    <hr>

                                    <div class="mb-4">
                                        <p class="text-muted small mb-1">Giá Vé</p>
                                        <p class="fw-bold fs-5 text-success mb-0">
                                            <%= ticket.price.toLocaleString('vi-VN') %> ₫
                                        </p>
                                    </div>

                                    <div class="d-grid gap-2">
                                        <a href="/booking/DanhSachDatVe" class="btn btn-outline-primary">
                                            <i class="bi bi-arrow-left me-1"></i> Quay Lại
                                        </a>
                                        <button class="btn btn-danger" onclick="cancelTicket('<%= ticket._id %>')">
                                            <i class="bi bi-trash me-1"></i> Hủy Vé
                                        </button>
                                    </div>

                                    <div class="alert alert-warning mt-3 mb-0" role="alert">
                                        <small>
                                            <i class="bi bi-exclamation-triangle me-1"></i>
                                            Hủy vé sẽ được hoàn tiền 100% nếu thực hiện trước 24 giờ khi khởi hành.
                                        </small>
                                    </div>
                                </div>
                            </div>

                            <!-- Thông Tin Liên Hệ -->
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">
                                        <i class="bi bi-question-circle me-2"></i>Cần Giúp Đỡ?
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <p class="small text-muted mb-3">
                                        Nếu bạn có bất kỳ câu hỏi về vé của mình, vui lòng liên hệ với chúng tôi.
                                    </p>
                                    <div class="mb-2">
                                        <p class="small mb-1">
                                            <i class="bi bi-telephone me-2"></i>
                                            <strong>Hotline:</strong> 1900-1234
                                        </p>
                                    </div>
                                    <div class="mb-2">
                                        <p class="small mb-1">
                                            <i class="bi bi-envelope me-2"></i>
                                            <strong>Email:</strong> support@airblink.com
                                        </p>
                                    </div>
                                    <div>
                                        <p class="small mb-0">
                                            <i class="bi bi-clock me-2"></i>
                                            <strong>Giờ Hành Chính:</strong> 8:00 - 22:00
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                <% } else { %>
                    <!-- Error State -->
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-circle me-2"></i>
                        <strong>Lỗi!</strong> Không thể tìm thấy thông tin vé. Vé có thể đã bị xóa hoặc chuyến bay không còn tồn tại.
                        <a href="/booking/DanhSachDatVe" class="alert-link">Quay lại danh sách vé</a>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>
            </div>
        </div>

        <%- include('Footer') %>
        <%- include('Javascript') %>
    </div>

    <script>
        function cancelTicket(ticketId) {
            if (confirm('Bạn có chắc chắn muốn hủy vé này không? Vé sẽ được hoàn tiền.')) {
                window.location.href = '/booking/HuyVe/' + ticketId;
            }
        }
    </script>

</body>

</html>
