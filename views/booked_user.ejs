<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="/css/Navbar.css" />
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %> - Danh sách vé đã đặt </title>
</head>
<body>

    <div class="container-fluid min-vh-100 px-1 d-flex flex-column">
        <%- include('Navbar') %>
        
        <div class="flex-grow-1 py-5">
            <div class="container">
                <!-- Header -->
                <div class="mb-5">
                    <h1 class="fw-bold mb-2">
                        <i class="bi bi-ticket-perforated me-2"></i>Danh sách vé đã đặt
                    </h1>
                    <p class="text-muted">Quản lý và xem chi tiết các chuyến bay bạn đã đặt vé</p>
                    <hr class="border-primary border-2 w-25">
                </div>

                <!-- Filters & Controls -->
                <div class="row mb-4">
                    <div class="col-md-6 mb-3">
                        <div class="input-group">
                            <span class="input-group-text border-0 bg-light">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" class="form-control border-0 bg-light" id="searchInput" 
                                   placeholder="Tìm kiếm theo tên chuyến bay...">
                        </div>
                    </div>
                    <div class="col-md-6 mb-3 text-md-end">
                        <a href="/booking" class="btn btn-primary">
                            <i class="bi bi-plus-circle me-1"></i> Đặt vé mới
                        </a>
                    </div>
                </div>

                <!-- Danh sách vé -->
                <% if (tickets && tickets.length > 0) { %>
                    <!-- Dạng Desktop - Table -->
                    <div class="d-none d-md-block">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 15%">
                                            <i class="bi bi-airplane me-2"></i>Tên chuyến bay
                                        </th>
                                        <th>
                                            <i class="bi bi-geo-alt-fill me-2"></i>Điểm đến
                                        </th>
                                        <th style="width: 15%">
                                            <i class="bi bi-calendar-event me-2"></i>Ngày bay
                                        </th>
                                        <th style="width: 12%">
                                            <i class="bi bi-chair me-2"></i>Ghế
                                        </th>
                                        <th style="width: 15%">
                                            <i class="bi bi-cash me-2"></i>Giá vé
                                        </th>
                                        <th style="width: 20%">Mô tả</th>
                                        <th style="width: 23%; text-align: center;">Hành động</th>
                                    </tr>
                                </thead>
                                <tbody id="ticketTableBody">
                                    <% tickets.forEach(ticket => { %>
                                        <% if (ticket.chuyenbay) { %>
                                        <tr class="ticket-row" data-ticket-name="<%= ticket.chuyenbay.name.toLowerCase() %>">
                                            <td>
                                                <strong><%= ticket.chuyenbay.name %></strong>
                                            </td>
                                            <td>
                                                <strong><%= ticket.chuyenbay.from_airport %> - <%= ticket.chuyenbay.to_airport %></strong>
                                            </td>
                                            <td>
                                                <strong><%= new Date(ticket.chuyenbay.flydate).toLocaleDateString('vi-VN', { year: 'numeric', month: '2-digit', day: '2-digit' }) %></strong>
                                            </td>
                                            <td>
                                                <span class="badge bg-info"><%= ticket.seatsplaced %></span>
                                            </td>
                                            <td>
                                                <strong class="text-success"><%= ticket.price.toLocaleString('vi-VN') %> ₫</strong>
                                            </td>
                                            <td>
                                                <small class="text-muted">
                                                    <%= ticket.description ? ticket.description.substring(0, 30) + '...' : 'Không có' %>
                                                </small>
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group btn-group-sm" role="group">
                                                    <a href="/booking/detail_ticket/<%= ticket._id %>" class="btn btn-outline-primary" 
                                                       title="Xem chi tiết">
                                                        <i class="bi bi-eye"></i>
                                                    </a>
                                                    <button class="btn btn-outline-danger" onclick="confirmCancel('<%= ticket._id %>')" 
                                                            title="Hủy vé">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                        <% } %>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Dạng Mobile - Cards -->
                    <div class="d-md-none">
                        <div class="row" id="ticketCardsContainer">
                            <% tickets.forEach(ticket => { %>
                                <% if (ticket.chuyenbay) { %>
                                <div class="col-12 mb-4 ticket-card" data-ticket-name="<%= ticket.chuyenbay.name.toLowerCase() %>">
                                    <div class="card border-0 shadow-sm h-100">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-start mb-3">
                                                <div>
                                                    <h5 class="card-title fw-bold mb-1"><%= ticket.chuyenbay.name %></h5>
                                                    <p class="text-muted mb-0">
                                                        <i class="bi bi-calendar-event me-1"></i>
                                                        <%= new Date(ticket.chuyenbay.flydate).toLocaleDateString('vi-VN', { year: 'numeric', month: '2-digit', day: '2-digit' }) %>
                                                    </p>
                                                </div>
                                                <span class="badge bg-success"><%= ticket.price.toLocaleString('vi-VN') %> ₫</span>
                                            </div>

                                            <div class="mb-3 pb-3 border-bottom">
                                                <p class="text-muted mb-2">
                                                    <i class="bi bi-geo-alt-fill me-2"></i>
                                                    <strong><%= ticket.chuyenbay.from_airport %></strong> → <strong><%= ticket.chuyenbay.to_airport %></strong>
                                                </p>
                                                <p class="text-muted mb-2">
                                                    <i class="bi bi-chair me-2"></i>
                                                    Ghế: <strong><%= ticket.seatsplaced %></strong>
                                                </p>
                                                <% if (ticket.description) { %>
                                                    <p class="text-muted mb-0">
                                                        <i class="bi bi-info-circle me-2"></i>
                                                        <%= ticket.description %>
                                                    </p>
                                                <% } %>
                                            </div>

                                            <div class="d-grid gap-2">
                                                <a href="/booking/detail_ticket/<%= ticket._id %>" class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-eye me-1"></i>Xem chi tiết
                                                </a>
                                                <button class="btn btn-sm btn-outline-danger" onclick="confirmCancel('<%= ticket._id %>')">
                                                    <i class="bi bi-trash me-1"></i>Hủy Vé
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <% } %>
                            <% }); %>
                        </div>
                    </div>

                <% } else { %>
                    <!-- Empty State -->
                    <div class="card border-0 bg-light shadow-sm">
                        <div class="card-body text-center py-5">
                            <div style="font-size: 3rem; color: #6c757d; margin-bottom: 1rem;">
                                <i class="bi bi-inbox"></i>
                            </div>
                            <h5 class="fw-bold mb-2">Bạn chưa đặt vé nào</h5>
                            <p class="text-muted mb-4">Hãy khám phá các chuyến bay và đặt vé ngay hôm nay!</p>
                        </div>
                    </div>
                <% } %>

                <!-- Pagination (nếu cần) -->
                <% if (tickets && tickets.length > 10) { %>
                    <nav aria-label="Page navigation" class="mt-5">
                        <ul class="pagination justify-content-center">
                            <li class="page-item"><a class="page-link" href="#">Trước</a></li>
                            <li class="page-item active"><a class="page-link" href="#">1</a></li>
                            <li class="page-item"><a class="page-link" href="#">2</a></li>
                            <li class="page-item"><a class="page-link" href="#">Tiếp</a></li>
                        </ul>
                    </nav>
                <% } %>
            </div>
        </div>
        
        <%- include('Footer') %>
        <%- include('Javascript') %>   

        <script>
            // Hàm tìm kiếm
            document.getElementById('searchInput')?.addEventListener('keyup', function(e) {
                const searchValue = e.target.value.toLowerCase();
                const rows = document.querySelectorAll('.ticket-row');
                const cards = document.querySelectorAll('.ticket-card');
                
                rows.forEach(row => {
                    if (row.dataset.ticketName.includes(searchValue)) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });

                cards.forEach(card => {
                    if (card.dataset.ticketName.includes(searchValue)) {
                        card.style.display = '';
                    } else {
                        card.style.display = 'none';
                    }
                });
            });

            // Hàm xác nhận hủy vé
            function confirmCancel(ticketId) {
                if (confirm('Bạn có chắc chắn muốn hủy vé này không?')) {
                    // Gửi request hủy vé
                    window.location.href = '/booking/HuyVe/' + ticketId;
                }
            }
        </script>
    </div>
</body>
</html>