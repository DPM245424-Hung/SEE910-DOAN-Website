<!DOCTYPE html>
<html lang="en">

<head>
    <link rel="stylesheet" href="/css/Navbar.css" />
    <link rel="stylesheet" href="/css/index.css">
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>
        <%= title %> - Chuyến bay
    </title>
</head>

<body>

    <div class="container-fluid min-vh-100 px-1 d-flex flex-column">
        <%- include('Navbar') %>
            <header class="hero">
                <div class="overlay">
                    <div class="content">
                        <h1>Khởi đầu hành trình của bạn</h1>
                        <p>Khám phá những vùng đất mới với dịch vụ bay chuyên nghiệp và đẳng cấp nhất.</p>
                        <a href="/dangky" class="btn">Tìm hiểu thêm</a>
                    </div>
                </div>
            </header>
            <div class="container mt-5 mb-5 flex-grow-1">
                <h1 class="mb-4 text-center">
                    <i class="bi bi-airplane"></i> Các Chuyến Bay nổi bất gần đây
                </h1>
                <% if(flights && flights.length> 0) { %>

                    <div class="table-responsive">
                        <table class="table table-hover table-striped">
                            <thead class="table-dark">
                                <tr>
                                    <th class="text-center">Mã Chuyến</th>
                                    <th class="text-center">Hãng Hàng Không</th>
                                    <th class="text-center">Máy Bay</th>
                                    <th class="text-center">Từ - Đến</th>
                                    <th class="text-center">Ngày Bay</th>
                                    <th class="text-center">Giá (VNĐ)</th>
                                    <th class="text-center">Ghế Còn Lại</th>
                                    <th class="text-center">Trạng Thái</th>
                                    <th class="text-center">Hành Động</th>
                                </tr>
                            </thead>
                            <tbody id="flightTableBody">
                                <% flights.forEach(function(flight) { const seatsRemaining=flight.numberseats -
                                    flight.numberseats_pick; const flyDate=new Date(flight.flydate); const
                                    dateStr=flyDate.toLocaleDateString('vi-VN', { year: 'numeric' , month: '2-digit' ,
                                    day: '2-digit' }); const timeStr=flyDate.toLocaleTimeString('vi-VN', {
                                    hour: '2-digit' , minute: '2-digit' }); %>
                                    <tr>
                                        <td class="text-center"><strong>
                                                <%= flight.name %>
                                            </strong></td>
                                        <td class="text-center">
                                            <%= flight.airline %>
                                        </td>
                                        <td class="text-center">
                                            <%= flight.airplane %>
                                        </td>
                                        <td class="text-center">
                                            <%= flight.from_airport %> <i class="bi bi-arrow-right"></i>
                                                <%= flight.to_airport %>
                                        </td>
                                        <td class="text-center">
                                            <div>
                                                <%= dateStr %>
                                            </div>
                                            <small class="text-muted">
                                                <%= timeStr %>
                                            </small>
                                        </td>
                                        <td class="text-center">
                                            <strong class="text-primary">
                                                <%= flight.price.toLocaleString('vi-VN') %>
                                            </strong>
                                        </td>
                                        <td class="text-center">
                                            <% if(seatsRemaining> 0) { %>
                                                <span class="badge bg-success">
                                                    <%= seatsRemaining %> ghế
                                                </span>
                                                <% } else { %>
                                                    <span class="badge bg-danger">Hết chỗ</span>
                                                    <% } %>
                                        </td>
                                        <td class="text-center">
                                            <% if(seatsRemaining> 0 && flight.status === 'active') { %>
                                                <span class="badge bg-info">Có sẵn</span>
                                                <% } else { %>
                                                    <span class="badge bg-secondary">Không khả dụng</span>
                                                    <% } %>
                                        </td>
                                        <td class="text-center">
                                            <% if(seatsRemaining> 0 && flight.status === 'active' || flight.status ===
                                                'Hoạt động') { %>
                                                <% if(session.user) { %>
                                                    <a href="/booking?flightId=<%= flight._id %>"
                                                        class="btn btn-sm btn-primary">
                                                        <i class="bi bi-bag-check"></i> Đặt Vé
                                                    </a>
                                                    <% } else { %>
                                                        <button class="btn btn-sm btn-warning"
                                                            onclick="redirectToSignUp()">
                                                            <i class="bi bi-person-plus"></i> Đăng Ký
                                                        </button>
                                                        <% } %>
                                                            <% } else { %>
                                                                <button class="btn btn-sm btn-secondary" disabled>
                                                                    Không có sẵn
                                                                </button>
                                                                <% } %>
                                        </td>
                                    </tr>
                                    <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                        <div class="alert alert-info text-center" role="alert">
                            <i class="bi bi-info-circle"></i> Hiện không có chuyến bay nào khả dụng
                        </div>
                        <% } %>
            </div>

            <%- include('Footer') %>
                <%- include('Javascript') %>
    </div>

    <script>
        function redirectToSignUp() {
            if (confirm('Bạn cần đăng ký tài khoản để đặt vé. Bạn có muốn đăng ký ngay không?')) {
                window.location.href = '/dangky';
            }
        }
    </script>

</body>

</html>