<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title><%= title %> - Trang chủ </title>
    <link href="/css/Navbar.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/background.css" />
</head>
<body>

    <div class="container-fluid min-vh-100 px-1 d-flex flex-column">
        <%- include('Navbar') %>
        <div class="flex-grow-1 d-flex align-items-center justify-content-center py-5">
            <div class="card shadow" style="width: 100%; max-width: 450px; border-radius: 15px;">
                <div class="card-body p-5">
                    <h2 class="text-center mb-4 fw-bold">Đăng Ký</h2>
                    
                    <form action="/dangky" method="post" class="needs-validation" novalidate>
                        <!-- Tên tài khoản -->
                        <div class="mb-3">
                            <label for="tentaikhoan" class="form-label">Tên tài khoản</label>
                            <input type="text" class="form-control" id="tentaikhoan" name="Tentaikhoan" required placeholder="Nhập tên tài khoản">
                            <div class="invalid-feedback">Vui lòng nhập tên tài khoản.</div>
                        </div>

                        <!-- Email -->
                        <div class="mb-3">
                            <label for="email" class="form-label">Email</label>
                            <input type="email" class="form-control" id="email" name="Email" required placeholder="Nhập địa chỉ email">
                            <div class="invalid-feedback">Vui lòng nhập email hợp lệ.</div>
                        </div>

                        <!-- Mật khẩu -->
                        <div class="mb-4">
                            <label for="matkhau" class="form-label">Mật khẩu</label>
                            <input type="password" class="form-control" id="matkhau" name="MatKhau" required 
                                   placeholder="Nhập mật khẩu" minlength="6">
                            <div class="invalid-feedback">Vui lòng nhập mật khẩu (tối thiểu 6 ký tự).</div>
                            <small class="form-text text-muted d-block mt-2">Mật khẩu phải có ít nhất 6 ký tự.</small>
                        </div>
                        <div class="mb-4">
                            <label for="xacnhanmatkhau" class="form-label">Xác nhận mật khẩu</label>
                            <input type="password" class="form-control" id="xacnhanmatkhau" name="XacNhanMatKhau" required 
                                   placeholder="Nhập lại mật khẩu" minlength="6">
                            <div class="invalid-feedback" id="passwordMatchFeedback">Vui lòng xác nhận mật khẩu.</div>
                            <small class="form-text text-muted d-block mt-2" id="passwordMatch" style="color: #6c757d !important;">
                                Mật khẩu chưa trùng khớp
                            </small>
                        </div>

                        <!-- Nút Đăng ký -->
                        <button type="submit" class="btn btn-success w-100 py-2 fw-bold mb-3" id="submitBtn">Đăng Ký</button>
                    </form>

                    <!-- Liên kết tới Đăng nhập -->
                    <div class="text-center">
                        <p class="text-muted mb-0">Đã có tài khoản? 
                            <a href="/dangnhap" class="text-decoration-none fw-bold">Đăng nhập ngay</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>  
        <script>
            // Kiểm tra mật khẩu trùng khớp
            const matkhauInput = document.getElementById('matkhau');
            const xacnhanInput = document.getElementById('xacnhanmatkhau');
            const passwordMatchText = document.getElementById('passwordMatch');
            const form = document.querySelector('form');

            function checkPasswordMatch() {
                if (matkhauInput.value === '' && xacnhanInput.value === '') {
                    passwordMatchText.textContent = 'Mật khẩu chưa được nhập';
                    passwordMatchText.style.color = '#6c757d';
                    xacnhanInput.classList.remove('is-valid', 'is-invalid');
                    return false;
                }

                if (matkhauInput.value === xacnhanInput.value && xacnhanInput.value !== '') {
                    passwordMatchText.textContent = '✓ Mật khẩu trùng khớp';
                    passwordMatchText.style.color = '#198754';
                    xacnhanInput.classList.remove('is-invalid');
                    xacnhanInput.classList.add('is-valid');
                    return true;
                } else if (xacnhanInput.value !== '') {
                    passwordMatchText.textContent = '✗ Mật khẩu không trùng khớp';
                    passwordMatchText.style.color = '#dc3545';
                    xacnhanInput.classList.remove('is-valid');
                    xacnhanInput.classList.add('is-invalid');
                    return false;
                }

                return false;
            }

            // Lắng nghe sự kiện nhập liệu
            matkhauInput.addEventListener('input', checkPasswordMatch);
            xacnhanInput.addEventListener('input', checkPasswordMatch);

            // Kiểm tra trước khi submit
            form.addEventListener('submit', function(e) {
                if (matkhauInput.value !== xacnhanInput.value) {
                    e.preventDefault();
                    e.stopPropagation();
                    xacnhanInput.classList.add('is-invalid');
                    alert('Mật khẩu không trùng khớp. Vui lòng kiểm tra lại!');
                    return false;
                }

                // Kiểm tra độ dài mật khẩu
                if (matkhauInput.value.length < 6) {
                    e.preventDefault();
                    e.stopPropagation();
                    matkhauInput.classList.add('is-invalid');
                    alert('Mật khẩu phải có ít nhất 6 ký tự!');
                    return false;
                }
            });
        </script>
         <%- include('Footer') %>
         <%- include('Javascript') %> 
    </div>
</body>
</html>