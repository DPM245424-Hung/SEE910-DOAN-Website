<!DOCTYPE html>
<html lang="en">

<head>
    <link rel="stylesheet" href="/css/Navbar.css" />
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>
        <%= title %> - Chuyến bay 
    </title>
    <link rel="stylesheet" href="/css/background.css" />
</head>

<body>

    <div class="container-fluid min-vh-100 px-1 d-flex flex-column">
        <%- include('Navbar') %>
        
        <div class="container mt-5 mb-5 flex-grow-1">
            <h1 class="mb-4 text-center">
                <i class="bi bi-airplane"></i> Lịch Trình Chuyến Bay
            </h1>

            <div class="row mb-4">
                <div class="col-md-6 offset-md-3">
                    <div class="input-group shadow-sm">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" id="searchInput" class="form-control" placeholder="Tìm kiếm theo mã chuyến, hãng, điểm đến, ngày bay...">
                    </div>
                </div>
            </div>
            <% if(flights && flights.length > 0) { %>
               
                <div class="table-responsive">
                    <table class="table table-hover table-striped">
                        <thead class="table-dark">
                            <tr>
                                <th class="text-center">Mã Chuyến</th>
                                <th class="text-center">Hãng Hàng Không</th>
                                <th class="text-center">Máy Bay</th>
                                <th class="text-center">Từ - Đến</th>
                                <th class="text-center">Ngày Bay</th>
                                <th class="text-center">Giá (VNĐ)</th>
                                <th class="text-center">Ghế Còn Lại</th>
                                <th class="text-center">Trạng Thái</th>
                                <th class="text-center">Hành Động</th>
                            </tr>
                        </thead>
                        <tbody id="flightTableBody">
                        <% flights.forEach(function(flight) {
                                const seatsRemaining = flight.numberseats - flight.numberseats_pick;
                                const flyDate = new Date(flight.flydate);
                                const dateStr = flyDate.toLocaleDateString('vi-VN', { year: 'numeric', month: '2-digit', day: '2-digit' });
                                const timeStr = flyDate.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
                            %>
                            <tr class="flight-row" data-flydate="<%= flight.flydate %>" data-flight-id="<%= flight._id %>">
                                <td class="text-center"><strong><%= flight.name %></strong></td>
                                <td class="text-center"><%= flight.airline %></td>
                                <td class="text-center"><%= flight.airplane %></td>
                                <td class="text-center">
                                    <%= flight.from_airport %> <i class="bi bi-arrow-right"></i> <%= flight.to_airport %>
                                </td>
                                <td class="text-center">
                                    <div><%= dateStr %></div>
                                    <small class="text-muted"><%= timeStr %></small>
                                </td>
                                <td class="text-center">
                                    <strong class="text-primary"><%= flight.price.toLocaleString('vi-VN') %></strong>
                                </td>
                                <td class="text-center">
                                    <% if(seatsRemaining > 0) { %>
                                        <span class="badge bg-success"><%= seatsRemaining %> ghế</span>
                                    <% } else { %>
                                        <span class="badge bg-danger">Hết chỗ</span>
                                    <% } %>
                                </td>
                                <td class="text-center">
                                    <span class="flight-status-badge badge" data-flydate="<%= flight.flydate %>">
                                        <!-- Trạng thái sẽ được cập nhật bằng JavaScript -->
                                    </span>
                                </td>
                                <td class="text-center">
                                    <% if(seatsRemaining > 0 && flight.status === 'active') { %>
                                        <% if(session.user) { %>
                                            <a href="/booking?flightId=<%= flight._id %>" class="btn btn-sm btn-primary flight-action-btn">
                                                <i class="bi bi-bag-check"></i> Đặt Vé
                                            </a>
                                        <% } else { %>
                                            <button class="btn btn-sm btn-warning flight-action-btn" onclick="redirectToSignUp()">
                                                <i class="bi bi-person-plus"></i> Đăng Ký
                                            </button>
                                        <% } %>
                                    <% } else { %>
                                        <button class="btn btn-sm btn-secondary flight-action-btn" disabled>
                                            Không có sẵn
                                        </button>
                                    <% } %>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="alert alert-info text-center" role="alert">
                    <i class="bi bi-info-circle"></i> Hiện không có chuyến bay nào khả dụng
                </div>
            <% } %>
        </div>

        <%- include('Footer') %>
        <%- include('Javascript') %>
    </div>

    <script src="/js/status.js"></script>
    <script>
        function redirectToSignUp() {
            if(confirm('Bạn cần đăng ký tài khoản để đặt vé. Bạn có muốn đăng ký ngay không?')) {
                window.location.href = '/dangky';
            }
        }

        // BẮT ĐẦU: Xử lý logic tìm kiếm trực tiếp trên bảng
        document.addEventListener('DOMContentLoaded', function() {
            // Cập nhật trạng thái chuyến bay
            initFlightStatusUpdater(updateFlightStatuses);
            
            const searchInput = document.getElementById('searchInput');
            const tableBody = document.getElementById('flightTableBody');

            if (searchInput && tableBody) {
                searchInput.addEventListener('input', function() {
                    // Chuyển từ khóa về chữ thường để tìm kiếm không phân biệt hoa/thường
                    const searchTerm = this.value.toLowerCase();
                    const rows = tableBody.getElementsByTagName('tr');

                    // Lặp qua từng hàng (tr) trong bảng
                    for (let i = 0; i < rows.length; i++) {
                        // Lấy toàn bộ nội dung text của hàng đó
                        const rowText = rows[i].textContent.toLowerCase();
                        
                        // Nếu nội dung chứa từ khóa thì hiển thị, ngược lại thì ẩn đi
                        if (rowText.includes(searchTerm)) {
                            rows[i].style.display = '';
                        } else {
                            rows[i].style.display = 'none';
                        }
                    }
                });
            }
        });
        // KẾT THÚC: Xử lý logic tìm kiếm
    </script>

</body>

</html>